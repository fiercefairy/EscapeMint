# EscapeMint Configuration
# Note: Port configuration is centralized in ecosystem.config.cjs

# Data directory (relative to project root)
DATA_DIR=./data

# Backup directory (defaults to ~/Library/Mobile Documents/com~apple~CloudDocs/EscapeMint-Backups on macOS)
# BACKUP_DIR=/path/to/backup/folder

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Node environment
NODE_ENV=development
