{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "noEmit": true,
    "paths": {
      "~pages/*": ["../../pages/src/*"],
      "~web/*": ["./src/*"],
      "@escapemint/engine": ["../engine/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../../pages/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
